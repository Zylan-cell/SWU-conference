---
import Layout from '../layouts/Layout.astro';
import content from '../i18n/bg/pages.json';

const pdfUrl = "https://drive.google.com/file/d/1FekOsToGQeDAVaDk-HoU8pw_k4T85js4/preview";
const fullUrl = "https://drive.google.com/file/d/1FekOsToGQeDAVaDk-HoU8pw_k4T85js4/view?usp=drive_link";
---

<Layout title={content.program.title}>
	<main class="page program-page">
		<h1>{content.program.title}</h1>
		<p class="program-desc">{content.program.desc}</p>

		<div class="pdf-container">
			<div class="pdf-loader">
				<div class="spinner"></div>
			</div>
			<iframe 
				src={pdfUrl}
				width="100%" 
				height="100%" 
				allow="autoplay"
				style="border: none;"
				title={content.program.title}
				onload="this.parentNode.querySelector('.pdf-loader').style.display='none'"
			></iframe>
		</div>
	</main>
</Layout>
