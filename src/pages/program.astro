---
import Layout from '../layouts/Layout.astro';
import content from '../i18n/bg/pages.json';

const pdfUrl = import.meta.env.BASE_URL.replace(/\/$/, '') + "/program.pdf";
---

<Layout title={content.program.title}>
	<main class="page program-page">
		<h1>{content.program.title}</h1>
		<div class="pdf-header">
			<p class="program-desc">{content.program.desc}</p>
			<a href={pdfUrl} download="SWU-Program.pdf" class="pdf-download-link">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="download-icon">
					<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
					<polyline points="7 10 12 15 17 10"></polyline>
					<line x1="12" y1="15" x2="12" y2="3"></line>
				</svg>
				Изтегли PDF
			</a>
		</div>

		<div class="pdf-container">
			<div class="pdf-loader">
				<div class="spinner"></div>
			</div>
			<iframe 
				src={pdfUrl + "#toolbar=0&navpanes=0"}
				width="100%" 
				height="100%" 
				allow="autoplay"
				style="border: none;"
				title={content.program.title}
				onload="this.parentNode.querySelector('.pdf-loader').style.display='none'"
			></iframe>
		</div>
	</main>
</Layout>
