---
import Layout from '../../layouts/Layout.astro';
import content from '../../i18n/en/pages.json';
import PhotoGallery from '../../components/PhotoGallery.astro';

const pdfUrl = import.meta.env.BASE_URL.replace(/\/$/, '') + "/program.pdf#navpanes=0";
---

<Layout title={content.program.title}>
	<main class="page program-page">
		<h1>{content.program.title}</h1>
		<p class="program-desc">{content.program.desc}</p>

		<div class="pdf-container">
			<div class="pdf-loader">
				<div class="spinner"></div>
			</div>
			<iframe 
				src={pdfUrl}
				width="100%" 
				height="100%" 
				allow="autoplay"
				style="border: none;"
				title={content.program.title}
				onload="this.parentNode.querySelector('.pdf-loader').style.display='none'"
			></iframe>
		</div>

		<!-- Photo gallery inserted at the bottom of the program page -->
		<PhotoGallery />
	</main>
</Layout>
